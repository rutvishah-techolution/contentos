# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` or the GCP service-account JSON.

# ── Claude (Azure AI Foundry — Anthropic Messages passthrough) ──
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com
AZURE_AI_FOUNDRY_API_KEY=<azure-foundry-key>
AZURE_CLAUDE_DEPLOYMENT=claude-opus-4-8
# AZURE_AI_FOUNDRY_API_VERSION=2024-10-01-preview   # optional override

# ── Grok (Azure AI Foundry — OpenAI-compatible chat/completions) ──
AZURE_GROK_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/openai/v1
AZURE_GROK_FOUNDRY_API_KEY=<grok-key>
# GROK_MODEL=grok-4.3                               # optional override

# ── Gemini (Google Vertex AI) ──
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GCP_PROJECT_ID=<your-gcp-project-id>
GCP_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.5-flash                     # optional override

# ── Optional models (parked; OpenAI-compatible via Azure Foundry) ──
# DeepSeek-V4-Pro_API_KEY=<deepseek-key>
# Kimi-K2.6_API_KEY=<kimi-key>

# ── Daily news-digest integration (read-only) ──
DIGEST_REPO_PATH=/absolute/path/to/daily-news-dump

# ── News engine ──
# Optional. If set, external callers (e.g. a cron job) must pass this as the
# `x-cron-secret` header or `?secret=` to trigger /api/news/scan. The in-app
# "Scan now" button (same-origin) works without it.
# NEWS_CRON_SECRET=<random-long-string>

# ── Auth.js (session signing) ──
# Generate: openssl rand -base64 32
AUTH_SECRET=<random-32-byte-base64>
